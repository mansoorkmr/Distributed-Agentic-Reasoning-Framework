
"""
Distributed Agentic Reasoning Framework (DARF)
Institutional Agent Runtime

Canonical Runtime Kernel

Responsibilities
----------------
- Agent registration
- Agent discovery
- Agent execution
- Runtime orchestration
- Lifecycle integration
- Metrics aggregation
- Health monitoring
- Execution tracking

Design Patterns
---------------
- Facade Pattern
- Registry Pattern
- State Machine Pattern
- Strategy Pattern
- Template Method Pattern

Complexity
----------
Registration: O(1)
Lookup: O(1)
Execution: O(1) runtime overhead
Health Check: O(n)
"""

from __future__ import annotations

import asyncio
import time
import uuid

from dataclasses import dataclass
from dataclasses import field

from typing import Any
from typing import Dict
from typing import Optional
from agents.base_agent import (
    BaseAgent,
    AgentContext,
)

from agents.runtime.agent_registry import (
    AgentRegistry,
)

from agents.runtime.runtime_metrics import (
    RuntimeMetrics,
)

from agents.runtime.runtime_context import (
    RuntimeContext,
)

from agents.runtime.execution_state import (
    ExecutionStateManager,
)

from agents.runtime.lifecycle_manager import (
    AgentLifecycleManager,
)

from agents.runtime.exceptions import (
    AgentNotFoundError,
    RuntimeValidationError,
)

# ============================================================
# EXECUTION REQUEST
# ============================================================


@dataclass(slots=True)
class AgentExecutionRequest:
    """
    Runtime execution request.
    """

    agent_id: str

    task: str

    metadata: Dict[str, Any] = field(
        default_factory=dict
    )

    request_id: str = field(
        default_factory=lambda: (
            str(uuid.uuid4())
        )
    )


# ============================================================
# EXECUTION RESULT
# ============================================================


@dataclass(slots=True)
class AgentExecutionResult:
    """
    Runtime execution result.
    """

    request_id: str

    agent_id: str

    success: bool

    output: Optional[str] = None

    error_message: Optional[str] = None

    latency_ms: float = 0.0

    execution_state: str = ""

# ============================================================
# AGENT RUNTIME
# ============================================================


class AgentRuntime:
    """
    Institutional Runtime Kernel.

    Coordinates:

    - Registry
    - Lifecycle
    - Execution State
    - Runtime Context
    - Metrics
    """

    def __init__(
        self,
    ) -> None:

        self._registry = (
            AgentRegistry()
        )

        self._metrics = (
            RuntimeMetrics()
        )

        self._lifecycle = (
            AgentLifecycleManager()
        )

        self._active_contexts: Dict[
            str,
            RuntimeContext,
        ] = {}

        self._lock = asyncio.Lock()

    # ========================================================
    # LOOKUP
    # ========================================================

    async def get_agent(
        self,
        agent_id: str,
    ) -> BaseAgent:

        return (
            await self._registry
            .get_agent(agent_id)
        )

    async def list_agents(
        self,
    ):

        return (
            await self._registry
            .list_agents()
        )

    async def registry_snapshot(
        self,
    ):

        return (
            await self._registry
            .snapshot()
        )
    # ========================================================
    # REGISTRATION
    # ========================================================

    async def register_agent(
        self,
        agent_id: str,
        agent: BaseAgent,
    ) -> None:

        if not agent_id.strip():

            raise RuntimeValidationError(
                "agent_id cannot be empty"
            )

        async with self._lock:

            await self._registry.register_agent(
                agent_id,
                agent,
            )

            self._metrics.registered_agents += 1

    async def unregister_agent(
        self,
        agent_id: str,
    ) -> None:

        async with self._lock:

            await self._registry.unregister_agent(
                agent_id
            )

            if (
                self._metrics.registered_agents
                > 0
            ):
                self._metrics.registered_agents -= 1


    # ========================================================
    # HEALTH
    # ========================================================

    async def health_check(
        self,
    ) -> Dict[str, Any]:

        registry = (
            await self._registry.health_check()
        )

        lifecycle = (
            await self._lifecycle.health_check()
        )

        return {
            "status": "healthy",
            "registry": registry,
            "lifecycle": lifecycle,
            "metrics":
                self._metrics.to_dict(),
            "active_contexts":
                len(
                    self._active_contexts
                ),
        }
    # ========================================================
    # VALIDATION
    # ========================================================

    def _validate_request(
        self,
        request: AgentExecutionRequest,
    ) -> None:

        if not isinstance(
            request,
            AgentExecutionRequest,
        ):
            raise RuntimeValidationError(
                "Invalid request type"
            )

        if not request.agent_id.strip():
            raise RuntimeValidationError(
                "agent_id cannot be empty"
            )

        if not request.task.strip():
            raise RuntimeValidationError(
                "task cannot be empty"
            )
    # ========================================================
    # EXECUTION
    # ========================================================

    async def execute(
        self,
        request: AgentExecutionRequest,
    ) -> AgentExecutionResult:

        self._validate_request(
            request
        )

        start_time = time.time()

        execution_state = (
            ExecutionStateManager()
        )

        runtime_context = (
            RuntimeContext()
        )

        self._active_contexts[
            request.request_id
        ] = runtime_context

        try:

            agent = (
                await self._registry
                .get_agent(
                    request.agent_id
                )
            )

        except Exception as exc:

            raise AgentNotFoundError(
                f"Agent not found: "
                f"{request.agent_id}"
            ) from exc

        try:

            runtime_context.start_execution()

            execution_state.transition_to(
                execution_state.current_state.QUEUED
            )

            execution_state.transition_to(
                execution_state.current_state.PLANNING
            )

            execution_state.transition_to(
                execution_state.current_state.REASONING
            )

            execution_state.transition_to(
                execution_state.current_state.DISPATCHING
            )

            execution_state.transition_to(
                execution_state.current_state.EXECUTING
            )

            await self._lifecycle.transition(
                request.agent_id,
                AgentLifecycleState.EXECUTING,
                reason="runtime_execute",
            )

            agent_context = AgentContext(
                metadata=request.metadata
            )

            output = await asyncio.to_thread(
                agent.execute,
                request.task,
                agent_context,
            )

            execution_state.transition_to(
                execution_state.current_state.COMPLETED
            )

            runtime_context.complete_execution()

            latency_ms = (
                time.time() - start_time
            ) * 1000

            self._metrics.record_execution_started()

            self._metrics.record_execution_completed(
                latency_ms
            )

            await self._lifecycle.transition(
                request.agent_id,
                AgentLifecycleState.IDLE,
                reason="execution_complete",
            )

            return AgentExecutionResult(
                request_id=request.request_id,
                agent_id=request.agent_id,
                success=True,
                output=output,
                latency_ms=latency_ms,
                execution_state="completed",
            )

        except Exception as exc:

            runtime_context.fail_execution(
                str(exc)
            )

            try:

                execution_state.transition_to(
                    execution_state.current_state.FAILED
                )

            except Exception:
                pass

            self._metrics.record_execution_started()

            self._metrics.record_execution_failed()

            try:

                await self._lifecycle.transition(
                    request.agent_id,
                    AgentLifecycleState.FAILED,
                    reason=str(exc),
                )

            except Exception:
                pass

            latency_ms = (
                time.time() - start_time
            ) * 1000

            return AgentExecutionResult(
                request_id=request.request_id,
                agent_id=request.agent_id,
                success=False,
                error_message=str(exc),
                latency_ms=latency_ms,
                execution_state="failed",
            )

        finally:

            self._active_contexts.pop(
                request.request_id,
                None,
            )
