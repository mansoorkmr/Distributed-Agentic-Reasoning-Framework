
"""
Distributed Agentic Reasoning Framework (DARF)
Institutional Agent Runtime

Canonical Runtime Kernel

Responsibilities
----------------
- Agent registration
- Agent discovery
- Agent execution
- Runtime orchestration
- Lifecycle integration
- Metrics aggregation
- Health monitoring
- Execution tracking

Design Patterns
---------------
- Facade Pattern
- Registry Pattern
- State Machine Pattern
- Strategy Pattern
- Template Method Pattern

Complexity
----------
Registration: O(1)
Lookup: O(1)
Execution: O(1) runtime overhead
Health Check: O(n)
"""

from __future__ import annotations

import asyncio
import time
import uuid

from dataclasses import dataclass
from dataclasses import field

from typing import Any
from typing import Dict
from typing import Optional
from agents.base_agent import (
    BaseAgent,
    AgentContext,
)

from agents.runtime.agent_registry import (
    AgentRegistry,
)

from agents.runtime.runtime_metrics import (
    RuntimeMetrics,
)

from agents.runtime.runtime_context import (
    RuntimeContext,
)

from agents.runtime.execution_state import (
    ExecutionStateManager,
)

from agents.runtime.lifecycle_manager import (
    AgentLifecycleManager,
)

from agents.runtime.exceptions import (
    AgentNotFoundError,
    RuntimeValidationError,
)

# ============================================================
# EXECUTION REQUEST
# ============================================================


@dataclass(slots=True)
class AgentExecutionRequest:
    """
    Runtime execution request.
    """

    agent_id: str

    task: str

    metadata: Dict[str, Any] = field(
        default_factory=dict
    )

    request_id: str = field(
        default_factory=lambda: (
            str(uuid.uuid4())
        )
    )


# ============================================================
# EXECUTION RESULT
# ============================================================


@dataclass(slots=True)
class AgentExecutionResult:
    """
    Runtime execution result.
    """

    request_id: str

    agent_id: str

    success: bool

    output: Optional[str] = None

    error_message: Optional[str] = None

    latency_ms: float = 0.0

    execution_state: str = ""

# ============================================================
# AGENT RUNTIME
# ============================================================


class AgentRuntime:
    """
    Institutional Runtime Kernel.

    Coordinates:

    - Registry
    - Lifecycle
    - Execution State
    - Runtime Context
    - Metrics
    """

    def __init__(
        self,
    ) -> None:

        self._registry = (
            AgentRegistry()
        )

        self._metrics = (
            RuntimeMetrics()
        )

        self._lifecycle = (
            AgentLifecycleManager()
        )

        self._active_contexts: Dict[
            str,
            RuntimeContext,
        ] = {}

        self._lock = asyncio.Lock()

    # ========================================================
    # LOOKUP
    # ========================================================

    async def get_agent(
        self,
        agent_id: str,
    ) -> BaseAgent:

        return (
            await self._registry
            .get_agent(agent_id)
        )

    async def list_agents(
        self,
    ):

        return (
            await self._registry
            .list_agents()
        )

    async def registry_snapshot(
        self,
    ):

        return (
            await self._registry
            .snapshot()
        )
    # ========================================================
    # REGISTRATION
    # ========================================================

    async def register_agent(
        self,
        agent_id: str,
        agent: BaseAgent,
    ) -> None:

        if not agent_id.strip():

            raise RuntimeValidationError(
                "agent_id cannot be empty"
            )

        async with self._lock:

            await self._registry.register_agent(
                agent_id,
                agent,
            )

            self._metrics.registered_agents += 1

    async def unregister_agent(
        self,
        agent_id: str,
    ) -> None:

        async with self._lock:

            await self._registry.unregister_agent(
                agent_id
            )

            if (
                self._metrics.registered_agents
                > 0
            ):
                self._metrics.registered_agents -= 1
